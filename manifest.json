{
  "manifest_version": 3,
  "name": "微信/小红书下载器",
  "version": "1.0.0",
  "description": "一键批量导出微信公众号文章和小红书笔记（包含高清原图、视频、全文描述及发布时间）为 HTML、Markdown 或图片 ZIP 包。",
  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*",
    "*://*.qpic.cn/*",
    "*://*.qpic.com.cn/*",
    "https://creator.xiaohongshu.com/*",
    "https://www.xiaohongshu.com/*",
    "*://*.xhscdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mp.weixin.qq.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "https://creator.xiaohongshu.com/*"
      ],
      "js": [
        "content/xhs_content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://creator.xiaohongshu.com/*"
      ],
      "js": [
        "content/xhs_inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
